# Copy to .env in this directory:  cp .env.example .env
# Put real secrets only in .env (gitignored). Never commit real keys to .env.example.

# --- Required for LLM (planner, curator, profiler) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_APP_TITLE=FillNinja

# Optional OpenRouter
# OPENROUTER_HTTP_REFERER=https://yoursite-or-github-readme-url
# OPENROUTER_MAX_COMPLETION_TOKENS=1024

# Optional alias for models that expect OPENAI_API_KEY
# OPENAI_API_KEY=

# --- Discovery search (optional; else DuckDuckGo via ddgs) ---
# FILLNINJA_SEARCH=auto
# TAVILY_API_KEY=

# --- Two-agent mode ---
# FILLNINJA_ENABLE_REVIEWER=1

# --- Video upload transcription (optional) ---
# FILLNINJA_WHISPER_API_KEY=
# FILLNINJA_WHISPER_BASE_URL=https://api.openai.com/v1
# FILLNINJA_WHISPER_MODEL=whisper-1
# FILLNINJA_FFMPEG_PATH=ffmpeg

# --- Code sandbox POST /sandbox/run (optional) ---
# FILLNINJA_CODE_BACKEND=daytona
# DAYTONA_API_KEY=dtn_replace_me
# DAYTONA_API_URL=https://app.daytona.io/api
# (Omit DAYTONA_API_URL to use the SDK default above. Do not use api.daytona.io — it is not the API host.)
# DAYTONA_TARGET=
# FILLNINJA_DAYTONA_SNAPSHOT=
# FILLNINJA_DAYTONA_IMAGE=python:3.12-slim
# FILLNINJA_CODE_TIMEOUT=120

# Or Docker instead of Daytona:
# FILLNINJA_CODE_BACKEND=docker
# FILLNINJA_DOCKER_IMAGE=python:3.12-slim
# FILLNINJA_DOCKER_NETWORK=none
