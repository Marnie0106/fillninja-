# OpenRouter (recommended — matches AG2 docs / build-with-ag2)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash
# Optional OpenRouter rankings headers
# OPENROUTER_HTTP_REFERER=https://yoursite-or-github-readme-url
OPENROUTER_APP_TITLE=FillNinja
# Optional token limit (passed to OpenAIConfig.max_completion_tokens)
# OPENROUTER_MAX_COMPLETION_TOKENS=1024

# Two-agent mode: AG2 planner + reviewer. Set 0/false/no to disable reviewer (planner only).
# FILLNINJA_ENABLE_REVIEWER=1

# Discovery search: Tavily (live web, free tier at https://app.tavily.com) or DuckDuckGo via ddgs.
# auto — use Tavily when TAVILY_API_KEY is set, otherwise ddgs.
# FILLNINJA_SEARCH=auto
# FILLNINJA_SEARCH=tavily
# FILLNINJA_SEARCH=ddgs
# Video uploads: ffmpeg must be on PATH; transcription uses OpenAI Whisper or compatible API (not OpenRouter chat).
# FILLNINJA_WHISPER_API_KEY=sk-...          # optional; falls back to OPENAI_API_KEY if set to a real OpenAI key
# FILLNINJA_WHISPER_BASE_URL=https://api.openai.com/v1
# FILLNINJA_WHISPER_MODEL=whisper-1
# FILLNINJA_FFMPEG_PATH=ffmpeg             # optional full path to ffmpeg

# Legacy alias (same value works for OpenRouter keys)
# OPENAI_API_KEY=sk-or-v1-...
