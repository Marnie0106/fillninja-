# Copy this file to .env and fill in your real values.
# NEVER commit .env — it is gitignored.
#
#   cp .env.example .env   # Linux / macOS / Git Bash
#   copy .env.example .env  # Windows PowerShell

# ── Required: LLM API ──────────────────────────────────────────────────────
# Get a free key at https://openrouter.ai (supports Gemini, Claude, GPT, etc.)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Model to use (default works well; change if you prefer another)
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_TITLE=FillNinja

# Optional: increase token limit for complex forms
# OPENROUTER_MAX_COMPLETION_TOKENS=1024

# ── Optional: Tavily Search API ────────────────────────────────────────────
# Leave blank to fall back to free DuckDuckGo search (ddgs)
# Sign up at https://tavily.com for a free key
TAVILY_API_KEY=

# ── Optional: Enable Planner + Reviewer two-agent mode ────────────────────
# Set to 1 to activate the 5th agent (Reviewer) that gates risky form actions
# FILLNINJA_ENABLE_REVIEWER=1
