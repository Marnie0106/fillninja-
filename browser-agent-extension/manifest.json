{
  "manifest_version": 3,
  "name": "FillNinja Agent",
  "version": "1.2.0",
  "description": "FillNinja: discover forms then fill tabs in two steps (local FastAPI + AG2)",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "background"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/fillninja.png",
      "48": "icons/fillninja.png",
      "128": "icons/fillninja.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/fillninja.png",
    "48": "icons/fillninja.png",
    "128": "icons/fillninja.png"
  }
}
